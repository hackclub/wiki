---
export interface Props {
  title: string;
  description?: string;
  banner?: string;
  noindex?: boolean;
}

const {
  title,
  description = "The community-maintained Hack Club knowledge base.",
  banner,
  noindex,
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = banner
  ? new URL(banner, Astro.site)
  : new URL("/og-default.png", Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("hc-wiki-theme");
        const theme =
          stored ||
          (window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light");
        document.documentElement.setAttribute("data-theme", theme);
        document.documentElement.style.colorScheme = theme;
      })();
    </script>

    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@hackclub" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title} — Hack Club Wiki</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
  @import "../styles/wiki.css";
  @import "../styles/syntax.css";
</style>
