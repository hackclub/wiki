---
export interface Props {
  title: string;
  description: string;
  categories: string[];
  banner?: string;
  stub?: boolean;
  lastEdited?: Date;
  author?: string;
}

const {
  title,
  description,
  categories,
  banner,
  stub = false,
  lastEdited,
} = Astro.props;

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
---

<header class="article-header">
  {
    stub && (
      <div class="stub-notice">
        <div class="stub-notice-icon" aria-hidden="true">
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
          </svg>
        </div>
        <div class="stub-notice-text">
          <strong>This article is a stub.</strong>
          It needs more content. Help expand it by editing on GitHub.
        </div>
      </div>
    )
  }

  {banner && <img src={banner} alt={title} class="article-banner" />}

  <div class="header-overlay">
    <h1 class="article-title">{title}</h1>
    {description && <p class="article-description">{description}</p>}
  </div>
  <div class="article-meta">
    {
      categories.length > 0 && (
        <div class="article-categories" aria-label="Categories">
          {categories.map((cat) => (
            <a
              href={`/category/${cat.toLowerCase().replace(/\s+/g, "-")}`}
              class="category-pill"
            >
              {cat}
            </a>
          ))}
        </div>
      )
    }

    {
      lastEdited && (
        <span class="article-date">
          <svg
            width="12"
            height="12"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
            <line x1="16" y1="2" x2="16" y2="6" />
            <line x1="8" y1="2" x2="8" y2="6" />
            <line x1="3" y1="10" x2="21" y2="10" />
          </svg>
          Last edited {formatDate(lastEdited)}
        </span>
      )
    }
  </div>
</header>

<style>
  .article-header {
    margin-bottom: 2.25rem;
    padding-bottom: 1.5rem;
    position: relative;
    overflow: hidden;
    background: var(--background);
    transition:
      background var(--transition-base),
      border-color var(--transition-base);
  }

  .article-banner {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: var(--radius-md);
    border: 2px solid var(--border);
    display: block;
    overflow: hidden;
  }

  .stub-notice {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    background: color-mix(in srgb, var(--yellow) 8%, var(--elevated));
    border: 1px solid color-mix(in srgb, var(--yellow) 30%, var(--border));
    border-radius: var(--radius-md);
    padding: 0.875rem 1.125rem;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  .stub-notice-icon {
    color: var(--yellow);
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .stub-notice-text {
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .stub-notice-text strong {
    display: block;
    margin-bottom: 0.2rem;
    color: var(--text);
    font-weight: 700;
  }

  .header-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 2rem 1.5rem;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      color-mix(in srgb, var(--background) 80%, transparent) 50%,
      var(--background) 100%
    );
    backdrop-filter: blur(1px);
    transition: background var(--transition-base);
  }

  .article-title {
    color: var(--text);
    margin-bottom: 0.15rem;
    font-size: 3rem;
    font-weight: 800;
    text-shadow:
      1px 0 var(--background),
      -1px 0 var(--background),
      0 1px var(--background),
      0 -1px var(--background),
      1px 1px var(--background),
      -1px -1px var(--background),
      1px -1px var(--background),
      -1px 1px var(--background);
    transition:
      color var(--transition-base),
      text-shadow var(--transition-base);
  }

  .article-description {
    color: var(--text-secondary);
    margin-bottom: 0;
    transition: color var(--transition-base);
  }

  .article-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .article-categories {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .category-pill {
    display: inline-flex;
    align-items: center;
    background: var(--red-dim);
    color: var(--red);
    border: 1px solid rgba(236, 55, 80, 0.22);
    border-radius: 999px;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    padding: 0.2rem 0.65rem;
    text-decoration: none;
    transition:
      background var(--transition-fast),
      border-color var(--transition-fast);
    cursor: pointer;
  }

  .category-pill:hover {
    background: rgba(236, 55, 80, 0.2);
    border-color: rgba(236, 55, 80, 0.38);
    color: var(--red);
  }

  .article-date {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.78rem;
    color: var(--muted);
  }
</style>
