---
export interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{tocHeadings.length > 0 && (
  <div class="toc-wrapper" id="toc-wrapper">
    <p class="toc-title">On this page</p>
    <nav aria-label="Table of contents">
      <ul class="toc-list" role="list">
        {tocHeadings.map((heading) => (
          <li class:list={['toc-item', `toc-depth-${heading.depth}`]}>
            <a
              href={`#${heading.slug}`}
              class="toc-link"
              data-heading-id={heading.slug}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
)}

<style>
  .toc-wrapper {
    position: sticky;
    top: 2rem;
    max-height: calc(100vh - 4rem);
    overflow-y: auto;
    padding: 0 0.5rem;
  }

  .toc-title {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.75rem;
  }

  .toc-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2px;
    border-left: 2px solid var(--border);
  }

  .toc-item {
    padding: 0;
  }

  .toc-link {
    display: block;
    font-size: 0.8125rem;
    color: var(--muted);
    text-decoration: none;
    padding: 0.2rem 0.75rem;
    border-left: 2px solid transparent;
    margin-left: -2px;
    line-height: 1.4;
    transition: color 0.15s ease, border-color 0.15s ease;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .toc-link:hover {
    color: var(--text);
  }

  .toc-link.active {
    color: var(--red);
    border-left-color: var(--red);
    font-weight: 600;
  }

  .toc-depth-3 .toc-link {
    padding-left: 1.5rem;
    font-size: 0.75rem;
  }
</style>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link[data-heading-id]');

  if (links.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            links.forEach((l) => l.classList.remove('active'));
            const id = entry.target.getAttribute('id');
            const active = document.querySelector<HTMLAnchorElement>(
              `.toc-link[data-heading-id="${id}"]`
            );
            active?.classList.add('active');
          }
        }
      },
      { rootMargin: '-20% 0% -70% 0%', threshold: 0 }
    );

    document.querySelectorAll('h2[id], h3[id]').forEach((h) => observer.observe(h));

    // Activate first link by default
    if (links[0]) links[0].classList.add('active');
  }
</script>
