---
import { getCollection } from 'astro:content';
import { getCategories } from '../../lib/getCategories';

const allPages = await getCollection('wiki');
const categories = getCategories(allPages);
const categoryNames = Object.keys(categories).sort();

const currentPath = Astro.url.pathname;

// Icon paths per category (stroke-based, 16x16 viewBox on 24 grid)
const categoryIcons: Record<string, string> = {
  clubs: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
  community: `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>`,
  events: `<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>`,
  'getting-started': `<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/>`,
  hardware: `<rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/>`,
  meta: `<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>`,
  projects: `<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>`,
  tools: `<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>`,
};

function getCategoryIcon(cat: string): string {
  const key = cat.toLowerCase().replace(/\s+/g, '-');
  return categoryIcons[key] ?? `<path d="M3 7h18M3 12h18M3 17h12"/>`;
}
---

<nav class="sidebar-nav" aria-label="Wiki navigation">
  <!-- Logo / Brand -->
  <div class="sidebar-brand">
    <a href="/" class="sidebar-logo" aria-label="Hack Club Wiki home">
      <div class="sidebar-logo-icon" aria-hidden="true">
        <svg width="30" height="30" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="100" height="100" rx="20" fill="#ec3750"/>
          <!-- Flag pole -->
          <rect x="34" y="21" width="5" height="62" rx="2.5" fill="white" opacity="0.95"/>
          <!-- Pennant flag -->
          <path d="M39 23 L79 37 L39 52 Z" fill="white"/>
          <!-- Ground base -->
          <ellipse cx="36.5" cy="85" rx="15" ry="5" fill="white" opacity="0.2"/>
        </svg>
      </div>
      <span class="sidebar-logo-text">
        <span class="sidebar-logo-name">Hack Club</span>
        <span class="sidebar-logo-wiki">Wiki</span>
      </span>
    </a>
  </div>

  <!-- Search -->
  <div class="sidebar-search-wrapper">
    <a href="/special/search" class="sidebar-search-btn" aria-label="Search wiki">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <span>Search…</span>
      <kbd>⌘K</kbd>
    </a>
  </div>

  <!-- Quick nav -->
  <div class="sidebar-section">
    <span class="sidebar-section-title">Navigation</span>
    <ul class="sidebar-links" role="list">
      <li>
        <a href="/" class:list={['sidebar-link', { active: currentPath === '/' }]}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
          Main Page
        </a>
      </li>
      <li>
        <a href="/special/all-pages" class:list={['sidebar-link', { active: currentPath.startsWith('/special/all-pages') }]}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <polyline points="10 9 9 9 8 9"/>
          </svg>
          All Pages
        </a>
      </li>
      <li>
        <a href="/special/categories" class:list={['sidebar-link', { active: currentPath.startsWith('/special/categories') }]}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
            <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
          </svg>
          Categories
        </a>
      </li>
      <li>
        <a href="/special/recent-changes" class:list={['sidebar-link', { active: currentPath.startsWith('/special/recent-changes') }]}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 3v5h5"/>
            <path d="M3.05 13A9 9 0 1 0 6 5.3L3 8"/>
          </svg>
          Recent Changes
        </a>
      </li>
    </ul>
  </div>

  <!-- Categories -->
  <div class="sidebar-section sidebar-categories">
    <span class="sidebar-section-title">Categories</span>
    <ul class="sidebar-links" role="list">
      {categoryNames.map((cat) => {
        const slug = cat.toLowerCase().replace(/\s+/g, '-');
        const icon = getCategoryIcon(cat);
        return (
          <li>
            <a
              href={`/category/${slug}`}
              class:list={['sidebar-link', { active: currentPath === `/category/${slug}` }]}
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icon} />
              {cat}
              <span class="category-count">{categories[cat].length}</span>
            </a>
          </li>
        );
      })}
    </ul>
  </div>

  <!-- Theme toggle + bottom links -->
  <div class="sidebar-footer">
    <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
      <svg class="icon-moon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
      <svg class="icon-sun" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="5"/>
        <line x1="12" y1="1" x2="12" y2="3"/>
        <line x1="12" y1="21" x2="12" y2="23"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="1" y1="12" x2="3" y2="12"/>
        <line x1="21" y1="12" x2="23" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <span class="theme-toggle-label">Toggle theme</span>
    </button>
    <a href="https://hackclub.com" class="sidebar-external" target="_blank" rel="noopener">
      <span>hackclub.com</span>
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
        <polyline points="15 3 21 3 21 9"/>
        <line x1="10" y1="14" x2="21" y2="3"/>
      </svg>
    </a>
  </div>
</nav>

<style>
  .sidebar-nav {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 0;
  }

  /* Brand */
  .sidebar-brand {
    padding: 1.125rem 1rem 1rem;
    border-bottom: 1px solid var(--border);
  }

  .sidebar-logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    color: var(--text);
  }

  .sidebar-logo-icon {
    flex-shrink: 0;
    border-radius: 10px;
    overflow: hidden;
    line-height: 0;
    box-shadow: 0 2px 8px rgba(236, 55, 80, 0.3);
  }

  .sidebar-logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
    gap: 1px;
  }

  .sidebar-logo-name {
    font-weight: 800;
    font-size: 0.9375rem;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .sidebar-logo-wiki {
    font-size: 0.6875rem;
    color: var(--muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 600;
  }

  /* Search */
  .sidebar-search-wrapper {
    padding: 0.75rem 0.875rem;
    border-bottom: 1px solid var(--border);
  }

  .sidebar-search-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    background: var(--sunken);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 0.45rem 0.7rem;
    color: var(--muted);
    text-decoration: none;
    font-size: 0.8125rem;
    cursor: pointer;
    transition: border-color var(--transition-fast), color var(--transition-fast), background var(--transition-fast);
  }

  .sidebar-search-btn:hover {
    border-color: var(--border-hover);
    color: var(--text-secondary);
    background: var(--elevated);
  }

  .sidebar-search-btn kbd {
    margin-left: auto;
    font-size: 0.6875rem;
    background: var(--elevated);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.1rem 0.35rem;
    color: var(--muted);
    font-family: var(--font-mono);
  }

  /* Sections */
  .sidebar-section {
    padding: 0.875rem 0.875rem 0.375rem;
    flex-shrink: 0;
  }

  .sidebar-categories {
    flex: 1;
    overflow-y: auto;
    padding-bottom: 0.5rem;
  }

  .sidebar-section-title {
    display: block;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.375rem;
    padding: 0 0.25rem;
  }

  /* Links */
  .sidebar-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.625rem;
    border-radius: var(--radius-sm);
    font-size: 0.8375rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: background var(--transition-fast), color var(--transition-fast);
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  .sidebar-link:hover {
    background: var(--elevated);
    color: var(--text);
  }

  .sidebar-link.active {
    background: var(--red-dim);
    color: var(--red);
    font-weight: 600;
  }

  .sidebar-link.active::before {
    content: '';
    position: absolute;
    left: 0;
    top: 20%;
    bottom: 20%;
    width: 2px;
    background: var(--red);
    border-radius: 0 2px 2px 0;
  }

  .sidebar-link svg {
    flex-shrink: 0;
    opacity: 0.6;
    transition: opacity var(--transition-fast);
  }

  .sidebar-link:hover svg,
  .sidebar-link.active svg {
    opacity: 1;
  }

  .category-count {
    margin-left: auto;
    font-size: 0.6875rem;
    color: var(--muted);
    background: var(--elevated-2);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.05rem 0.4rem;
    min-width: 1.25rem;
    text-align: center;
    flex-shrink: 0;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  /* Footer */
  .sidebar-footer {
    padding: 0.75rem 0.875rem;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: auto;
    flex-shrink: 0;
  }

  .theme-toggle {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    background: var(--elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--muted);
    cursor: pointer;
    font-size: 0.75rem;
    padding: 0.35rem 0.6rem;
    transition: all var(--transition-fast);
  }

  .theme-toggle:hover {
    border-color: var(--border-hover);
    color: var(--text);
  }

  .theme-toggle-label {
    font-family: var(--font-body);
    font-size: 0.75rem;
  }

  /* Show/hide sun/moon based on theme */
  :global([data-theme="dark"]) .icon-sun { display: none; }
  :global([data-theme="dark"]) .icon-moon { display: block; }
  :global([data-theme="light"]) .icon-sun { display: block; }
  :global([data-theme="light"]) .icon-moon { display: none; }

  .sidebar-external {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.6875rem;
    color: var(--muted);
    text-decoration: none;
    transition: color var(--transition-fast);
    white-space: nowrap;
  }

  .sidebar-external:hover {
    color: var(--red);
  }
</style>

<script>
  const toggle = document.getElementById('theme-toggle');
  toggle?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme');
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('hc-wiki-theme', next);
  });

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      window.location.href = '/special/search';
    }
  });
</script>
