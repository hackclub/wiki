---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import WikiLayout from "../components/layout/WikiLayout.astro";
import { getCategories, categorySlug } from "../lib/getCategories";
import { getRecentChanges } from "../lib/getRecentChanges";

const allPages = await getCollection("wiki");
const featured = allPages.filter((p) => p.data.featured);
const categories = getCategories(allPages);
const sortedCats = Object.keys(categories).sort();
const recentChanges = getRecentChanges(5);

// Category icons for the browse section
const catIcons: Record<string, string> = {
  clubs: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
  community: `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>`,
  events: `<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>`,
  "getting-started": `<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/>`,
  hardware: `<rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/>`,
  meta: `<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>`,
  projects: `<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>`,
  tools: `<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>`,
};

function getCatIcon(cat: string): string {
  const key = cat.toLowerCase().replace(/\s+/g, "-");
  return catIcons[key] ?? `<path d="M3 7h18M3 12h18M3 17h12"/>`;
}
---

<Base
  title="Hack Club Wiki"
  description="The community-maintained knowledge base for Hack Club — clubs, events, projects, and culture."
>
  <WikiLayout showToc={false}>
    <!-- Hero -->
    <section class="hero">
      <div class="hero-bg-grid" aria-hidden="true"></div>
      <div class="hero-content">
        <div class="hero-eyebrow">
          <span class="hero-badge">
            <svg
              width="10"
              height="10"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
              <path d="M2 17l10 5 10-5"></path>
              <path d="M2 12l10 5 10-5"></path>
            </svg>
            Community Wiki
          </span>
        </div>
        <h1 class="hero-title">
          <span class="hero-title-hack">Hack Club</span>
          <span class="hero-title-wiki">Wiki</span>
        </h1>
        <p class="hero-desc">
          The community-maintained knowledge base for Hack Club. Find everything
          about clubs, hackathons, programs, and the people who make it happen.
        </p>
        <div class="hero-actions">
          <a href="/wiki/getting-started" class="hero-btn hero-btn--primary">
            <svg
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path
                d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"
              ></path>
              <path
                d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"
              ></path>
            </svg>
            Get Started
          </a>
          <a href="/special/all-pages" class="hero-btn hero-btn--ghost">
            Browse All Pages
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>
      </div>

      <div class="hero-visual" aria-hidden="true">
        <div class="hero-mascot-ring"></div>
        <div class="hero-mascot-inner">
          <svg
            width="160"
            height="160"
            viewBox="0 0 200 200"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <defs>
              <radialGradient id="bg-glow" cx="50%" cy="50%" r="50%">
                <stop offset="0%" stop-color="#ec3750" stop-opacity="0.3"
                ></stop>
                <stop offset="100%" stop-color="#ec3750" stop-opacity="0"
                ></stop>
              </radialGradient>
              <linearGradient id="flag-grad" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#ec3750"></stop>
                <stop offset="100%" stop-color="#ff6b7a"></stop>
              </linearGradient>
              <linearGradient
                id="ground-grad"
                x1="0%"
                y1="0%"
                x2="0%"
                y2="100%"
              >
                <stop offset="0%" stop-color="#33d6a6" stop-opacity="0.5"
                ></stop>
                <stop offset="100%" stop-color="#33d6a6" stop-opacity="0.1"
                ></stop>
              </linearGradient>
            </defs>
            <!-- Background glow -->
            <circle cx="100" cy="100" r="88" fill="url(#bg-glow)"></circle>
            <!-- Ground -->
            <ellipse cx="100" cy="158" rx="52" ry="14" fill="url(#ground-grad)"
            ></ellipse>
            <!-- Ground ring -->
            <ellipse
              cx="100"
              cy="158"
              rx="30"
              ry="8"
              fill="#33d6a6"
              opacity="0.15"></ellipse>
            <!-- Pole -->
            <rect
              x="96.5"
              y="50"
              width="5"
              height="108"
              rx="2.5"
              fill="white"
              opacity="0.92"></rect>
            <!-- Flag -->
            <path d="M101.5 52 L158 72 L101.5 94 Z" fill="url(#flag-grad)"
            ></path>
            <!-- Flag shine -->
            <path d="M101.5 52 L158 72 L135 63 Z" fill="white" opacity="0.12"
            ></path>
            <!-- Base circle -->
            <circle cx="99" cy="158" r="6" fill="white" opacity="0.35"></circle>
          </svg>
        </div>
      </div>
    </section>

    <!-- Quick stats bar -->
    <div class="stats-bar">
      <a
        href="/special/all-pages"
        class="stat"
        aria-label="{allPages.length} articles"
      >
        <div class="stat-icon">
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
            ></path>
            <polyline points="14 2 14 8 20 8"></polyline>
          </svg>
        </div>
        <span class="stat-n">{allPages.length}</span>
        <span class="stat-label">Articles</span>
      </a>
      <div class="stat-divider" aria-hidden="true"></div>
      <a
        href="/special/categories"
        class="stat"
        aria-label="{sortedCats.length} categories"
      >
        <div class="stat-icon">
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="3" y="3" width="7" height="7"></rect><rect
              x="14"
              y="3"
              width="7"
              height="7"></rect>
            <rect x="14" y="14" width="7" height="7"></rect><rect
              x="3"
              y="14"
              width="7"
              height="7"></rect>
          </svg>
        </div>
        <span class="stat-n">{sortedCats.length}</span>
        <span class="stat-label">Categories</span>
      </a>
      <div class="stat-divider" aria-hidden="true"></div>
      <a
        href="https://hackclub.com/clubs"
        class="stat"
        target="_blank"
        rel="noopener"
        aria-label="1000+ clubs worldwide"
      >
        <div class="stat-icon">
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="2" y1="12" x2="22" y2="12"></line>
            <path
              d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
            ></path>
          </svg>
        </div>
        <span class="stat-n">1000+</span>
        <span class="stat-label">Clubs worldwide</span>
      </a>
      <div class="stat-divider" aria-hidden="true"></div>
      <a
        href="https://hackclub.com/slack"
        class="stat"
        target="_blank"
        rel="noopener"
        aria-label="100k+ members"
      >
        <div class="stat-icon">
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
            <circle cx="9" cy="7" r="4"></circle>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
          </svg>
        </div>
        <span class="stat-n">100k+</span>
        <span class="stat-label">Members</span>
      </a>
    </div>

    <!-- Featured Articles -->
    {
      featured.length > 0 && (
        <section class="home-section">
          <div class="section-header">
            <h2 class="section-title">Featured Articles</h2>
            <a href="/special/all-pages" class="section-more">
              All pages
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </a>
          </div>
          <div class="featured-grid">
            {featured.map((page) => (
              <a href={`/wiki/${page.id}`} class="featured-card">
                <div class="featured-card-top">
                  <div class="featured-card-cats">
                    {page.data.categories.slice(0, 2).map((c: string) => (
                      <span class="featured-cat">{c}</span>
                    ))}
                  </div>
                  <div class="featured-card-arrow" aria-hidden="true">
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <line x1="5" y1="12" x2="19" y2="12" />
                      <polyline points="12 5 19 12 12 19" />
                    </svg>
                  </div>
                </div>
                <h3 class="featured-card-title">{page.data.title}</h3>
                <p class="featured-card-desc">{page.data.description}</p>
                <span class="featured-read">
                  Read article
                  <svg
                    width="12"
                    height="12"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                  </svg>
                </span>
              </a>
            ))}
          </div>
        </section>
      )
    }

    <!-- Browse by Category -->
    <section class="home-section">
      <div class="section-header">
        <h2 class="section-title">Browse by Category</h2>
        <a href="/special/categories" class="section-more">
          All categories
          <svg
            width="13"
            height="13"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>
      <div class="cat-tags">
        {
          sortedCats.map((cat) => {
            const icon = getCatIcon(cat);
            return (
              <a href={`/category/${categorySlug(cat)}`} class="cat-tag">
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.75"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  set:html={icon}
                />
                {cat}
                <span class="cat-tag-count">{categories[cat].length}</span>
              </a>
            );
          })
        }
      </div>
    </section>

    <!-- Recent Changes -->
    <section class="home-section">
      <div class="section-header">
        <h2 class="section-title">Recent Changes</h2>
        <a href="/special/recent-changes" class="section-more">
          View all
          <svg
            width="13"
            height="13"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>

      {
        recentChanges.length === 0 ? (
          <div class="recent-empty">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="10" />
              <line x1="12" y1="8" x2="12" y2="12" />
              <line x1="12" y1="16" x2="12.01" y2="16" />
            </svg>
            <p>
              Recent changes will appear here once wiki articles have been
              committed to git.
            </p>
          </div>
        ) : (
          <ul class="recent-list" role="list">
            {recentChanges.map((change) => (
              <li class="recent-item">
                <div class="recent-meta">
                  <span class="recent-author">{change.author}</span>
                  <span class="recent-sep" aria-hidden="true">
                    ·
                  </span>
                  <time class="recent-time" datetime={change.date}>
                    {change.relativeDate}
                  </time>
                </div>
                <p class="recent-msg">{change.message}</p>
                {change.files.length > 0 && (
                  <div class="recent-files">
                    {change.files.slice(0, 3).map((f: string) => (
                      <a href={`/wiki/${f}`} class="recent-file">
                        {f}
                      </a>
                    ))}
                  </div>
                )}
              </li>
            ))}
          </ul>
        )
      }
    </section>
  </WikiLayout>
</Base>

<style>
  /* ---- Hero ---- */
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 3.5rem 0 3rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2.5rem;
    overflow: hidden;
  }

  .hero-bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 40px 40px;
    opacity: 0.25;
    mask-image: radial-gradient(
      ellipse 60% 100% at 80% 50%,
      black 20%,
      transparent 70%
    );
    pointer-events: none;
  }

  .hero-content {
    flex: 1;
    min-width: 0;
    position: relative;
    z-index: 1;
  }

  .hero-eyebrow {
    margin-bottom: 1rem;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--red-dim);
    color: var(--red);
    border: 1px solid rgba(236, 55, 80, 0.25);
    border-radius: 999px;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.8rem;
  }

  .hero-title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 900;
    line-height: 1;
    margin-bottom: 1rem;
    letter-spacing: -0.025em;
  }

  .hero-title-hack {
    color: var(--red);
    display: block;
  }

  .hero-title-wiki {
    color: var(--text);
    display: block;
  }

  .hero-desc {
    font-size: 1rem;
    color: var(--muted-2);
    line-height: 1.7;
    max-width: 460px;
    margin-bottom: 1.75rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.25rem;
    border-radius: var(--radius-md);
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.18s ease;
    cursor: pointer;
    letter-spacing: -0.01em;
  }

  .hero-btn--primary {
    background: var(--red);
    color: #fff;
    border: 1px solid var(--red);
    box-shadow: 0 2px 12px rgba(236, 55, 80, 0.3);
  }

  .hero-btn--primary:hover {
    background: #d42f46;
    color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(236, 55, 80, 0.4);
  }

  .hero-btn--ghost {
    background: var(--elevated);
    color: var(--text-secondary);
    border: 1px solid var(--border);
  }

  .hero-btn--ghost:hover {
    border-color: var(--border-hover);
    color: var(--text);
    transform: translateY(-1px);
  }

  /* Mascot */
  .hero-visual {
    position: relative;
    flex-shrink: 0;
    z-index: 1;
  }

  .hero-mascot-ring {
    position: absolute;
    inset: -16px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(236, 55, 80, 0.12) 0%,
      transparent 70%
    );
    animation: pulse-ring 3s ease-in-out infinite;
  }

  @keyframes pulse-ring {
    0%,
    100% {
      transform: scale(1);
      opacity: 1;
    }
    50% {
      transform: scale(1.06);
      opacity: 0.7;
    }
  }

  .hero-mascot-inner {
    animation: float 5s ease-in-out infinite;
    position: relative;
    z-index: 1;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-14px);
    }
  }

  /* ---- Stats bar ---- */
  .stats-bar {
    display: flex;
    align-items: stretch;
    background: var(--elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    margin-bottom: 3rem;
    overflow: hidden;
  }

  .stat {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1.25rem 0.75rem;
    gap: 0.3rem;
    text-decoration: none;
    color: var(--text);
    transition: background var(--transition-fast);
    cursor: pointer;
  }

  .stat:hover {
    background: var(--elevated-2);
  }

  .stat-icon {
    color: var(--muted);
    margin-bottom: 0.2rem;
    transition: color var(--transition-fast);
  }

  .stat:hover .stat-icon {
    color: var(--red);
  }

  .stat-n {
    font-size: 1.625rem;
    font-weight: 900;
    color: var(--red);
    line-height: 1;
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
  }

  .stat-label {
    font-size: 0.6875rem;
    color: var(--muted);
    text-align: center;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .stat-divider {
    width: 1px;
    background: var(--border);
    flex-shrink: 0;
    margin: 0.75rem 0;
  }

  /* ---- Sections ---- */
  .home-section {
    margin-bottom: 3rem;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .section-title {
    font-size: 1.125rem;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .section-more {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8125rem;
    color: var(--red);
    text-decoration: none;
    font-weight: 600;
    transition:
