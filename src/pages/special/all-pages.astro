---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import WikiLayout from '../../components/layout/WikiLayout.astro';
import Breadcrumb from '../../components/layout/Breadcrumb.astro';
import { getAlphabeticalGroups } from '../../lib/getAllPages';

const pages = await getCollection('wiki');
const groups = getAlphabeticalGroups(pages);
const letters = Object.keys(groups).sort();
const total = pages.length;
---

<Base title="All Pages" description={`Alphabetical index of all ${total} wiki articles.`}>
  <WikiLayout showToc={false}>
    <Breadcrumb crumbs={[{ label: 'All Pages' }]} />

    <header class="special-header">
      <h1>All Pages</h1>
      <p class="special-desc">{total} articles, sorted alphabetically.</p>
    </header>

    <!-- Letter quick-jump -->
    <div class="letter-jump" aria-label="Jump to letter">
      {letters.map((l) => (
        <a href={`#letter-${l}`} class="letter-btn">{l}</a>
      ))}
    </div>

    <!-- Article groups -->
    {letters.map((letter) => (
      <section class="alpha-group" id={`letter-${letter}`}>
        <h2 class="alpha-letter">{letter}</h2>
        <ul class="alpha-list" role="list">
          {groups[letter].map((page) => (
            <li class="alpha-item">
              <a href={`/wiki/${page.id}`} class="alpha-link">
                {page.data.title}
                {page.data.stub && <span class="stub-dot" title="Stub article" aria-label="stub"></span>}
              </a>
              <span class="alpha-desc">{page.data.description}</span>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </WikiLayout>
</Base>

<style>
  .special-header {
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .special-header h1 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 0.375rem;
  }

  .special-desc {
    color: var(--muted);
    font-size: 0.9375rem;
  }

  .letter-jump {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-bottom: 2rem;
  }

  .letter-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background: var(--elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--muted);
    text-decoration: none;
    transition: all 0.15s ease;
  }

  .letter-btn:hover {
    background: var(--red);
    border-color: var(--red);
    color: #fff;
  }

  .alpha-group {
    margin-bottom: 2rem;
  }

  .alpha-letter {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--red);
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.375rem;
    margin-bottom: 0.75rem;
  }

  .alpha-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .alpha-item {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.35rem 0.25rem;
    border-radius: var(--radius-sm);
    transition: background 0.1s ease;
  }

  .alpha-item:hover {
    background: var(--elevated);
  }

  .alpha-link {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--text);
    text-decoration: none;
    white-space: nowrap;
    min-width: 220px;
    flex-shrink: 0;
  }

  .alpha-link:hover {
    color: var(--red);
  }

  .stub-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--yellow);
    flex-shrink: 0;
  }

  .alpha-desc {
    font-size: 0.875rem;
    color: var(--muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (max-width: 48em) {
    .alpha-item {
      flex-direction: column;
      gap: 0.125rem;
    }
    .alpha-link {
      min-width: unset;
    }
  }
</style>
