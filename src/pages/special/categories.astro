---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import WikiLayout from "../../components/layout/WikiLayout.astro";
import Breadcrumb from "../../components/layout/Breadcrumb.astro";
import { getCategories, categorySlug } from "../../lib/getCategories";

const pages = await getCollection("wiki");
const categories = getCategories(pages);
const sortedCats = Object.keys(categories).sort((a, b) => a.localeCompare(b));
---

<Base title="Categories" description="All categories in the Hack Club Wiki.">
  <WikiLayout showToc={false}>
    <Breadcrumb crumbs={[{ label: "Categories" }]} />

    <header class="special-header">
      <h1>Categories</h1>
      <p class="special-desc">
        {sortedCats.length} categories across {pages.length} articles.
      </p>
    </header>

    <div class="cat-grid">
      {
        sortedCats.map((cat) => {
          const catPages = categories[cat];
          return (
            <a href={`/category/${categorySlug(cat)}`} class="cat-card">
              <div class="cat-card-name">{cat}</div>
              <div class="cat-card-count">
                {catPages.length}{" "}
                {catPages.length === 1 ? "article" : "articles"}
              </div>
              <ul class="cat-card-pages" aria-label={`Pages in ${cat}`}>
                {catPages.slice(0, 2).map((p) => (
                  <li>{p.data.title}</li>
                ))}
                {catPages.length > 2 && (
                  <li class="cat-card-more">+{catPages.length - 2} more</li>
                )}
              </ul>
              <img src="/the_thing_behind.png" class="cat-card-corner-icon" />
              <img src="/orpheus_silly.png" class="cat-card-top-icon" />
            </a>
          );
        })
      }
    </div>
  </WikiLayout>
</Base>

<style>
  .special-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .special-header h1 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 0.375rem;
  }

  .special-desc {
    color: var(--muted);
    font-size: 0.9375rem;
  }

  .cat-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1rem;
  }

  .cat-card {
    display: block;
    background: var(--elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.25rem;
    text-decoration: none;
    color: var(--text);
    transition:
      border-color 0.15s ease,
      transform 0.1s ease;
    position: relative;
    overflow: hidden;
  }

  .cat-card-corner-icon {
    width: 220px;
    position: absolute;
    bottom: -5px;
    object-fit: cover;
    right: -5px;
    object-fit: contain;
    z-index: 1;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }

  .cat-card:hover {
    border-color: var(--red);
    transform: translateY(-2px);
  }

  .cat-card-name {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.25rem;
    transition: color 0.15s ease;
  }

  .cat-card:hover .cat-card-name {
    color: var(--red);
  }

  .cat-card-count {
    font-size: 0.8125rem;
    color: var(--red);
    font-weight: 600;
    margin-bottom: 0.875rem;
  }

  .cat-card-pages {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-size: 0.8125rem;
    color: var(--muted);
  }

  .cat-card-pages li {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .cat-card-more {
    color: var(--blue);
    font-style: italic;
  }

  .cat-card-top-icon {
    position: absolute;
    bottom: 2px;
    right: 2px;
    width: 150px;
    z-index: 2;
    pointer-events: none;
    transition:
      transform 0.3s ease-out,
      opacity 0.2s ease;
  }

  .cat-card:hover .cat-card-top-icon {
    transform: scale(1.05) rotate(-5deg);
  }

  .cat-card:hover .cat-card-corner-icon {
    opacity: 0.9;
  }

  @media (max-width: 768px) {
    .cat-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
